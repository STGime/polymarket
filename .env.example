# Polymarket Weather Trading Bot — Environment Variables
# Copy this file to .env and fill in your values

# ─── Polymarket Credentials ───────────────────────────────
# Required for LIVE trading only. Dry run works without these.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# ─── Trading Settings ─────────────────────────────────────
BANKROLL_USD=1000
DRY_RUN=true

# ─── Optional API Keys ───────────────────────────────────
# AVWX provides parsed aviation weather (free tier available)
AVWX_API_KEY=

# UK Met Office DataHub — Site Specific Global Spot (free tier: 360 calls/day)
# Register at https://datahub.metoffice.gov.uk
METOFFICE_API_KEY=
